# Versions
EXAFLOW=1.0.0
PLATFORM_BACKEND=9.0.0
PLATFORM_UI=1.0.0
MIP=9.0.0

# Toggle authentication
AUTHENTICATION=0

# Toggle notebook route (/notebook) in platform-ui and start jupyterhub profile.
# 0 = off, 1 = on
NOTEBOOK_ENABLED=0

# Notebook proxy settings used by platform-ui when NOTEBOOK_ENABLED=1.
JUPYTER_SERVER=jupyterhub:8000
JUPYTER_CONTEXT=notebook
JUPYTER_LANDING_PATH=/hub/spawn

# Optional JupyterHub OAuth callback override.
# Keep this aligned with the URL where you access platform-ui.
JH_OAUTH_CALLBACK_URL=http://localhost/notebook/hub/oauth_callback

# Optional settings for local notebook mode when AUTHENTICATION=0.
# If empty, any username can login without a password.
JH_DUMMY_PASSWORD=
# Optional static token to inject in spawned notebooks.
PORTAL_TOKEN=

# Frontend base URL used for post-logout redirect.
PLATFORM_UI_BASE_URL=http://localhost

# External Keycloak
KEYCLOAK_AUTH_URL=https://iam.ebrains.eu/auth/
KEYCLOAK_REALM=MIP
KEYCLOAK_CLIENT_ID=mippublic
KEYCLOAK_CLIENT_SECRET=replace-me
KEYCLOAK_SSL_REQUIRED=none
